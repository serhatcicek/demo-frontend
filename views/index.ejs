<% title = 'Anasayfa' %>

<!-- HERO SECTION -->
<section class="hero" style="background: linear-gradient(135deg, var(--secondary) 0%, #2D3E5F 100%); color: white; padding: 6rem 2rem; text-align: center; border-radius: 12px; margin-bottom: 3rem;">
    <div style="max-width: 800px; margin: 0 auto;">
        <h1 style="font-size: 3rem; margin-bottom: 1rem; font-weight: 700;">Güvenilir Kiralama Çözümleri</h1>
        <p style="font-size: 1.25rem; margin-bottom: 2rem; color: #CBD5E1;">En iyi fiyatlarla premium araç kiralama hizmeti. Hızlı, güvenli ve kolay.</p>
        <a href="/vehicles" class="btn btn-primary" style="font-size: 1.1rem; padding: 1rem 2rem;">
            Araçları Keşfet →
        </a>
    </div>
</section>

<!-- CATEGORY FILTERS -->
<section class="mb-3">
    <h2 style="margin-bottom: 2rem; text-align: center; font-size: 2rem;">Araç Kategorileri</h2>
    <div class="grid grid-4" style="margin-bottom: 3rem;">
        <% const categories = [
            { name: 'Ekonomik', icon: '🚗', color: '#10B981' },
            { name: 'SUV', icon: '🏎️', color: '#3B82F6' },
            { name: 'Lüks', icon: '👑', color: '#F59E0B' },
            { name: 'Ticari', icon: '🚐', color: '#8B5CF6' }
        ]; %>
        <% categories.forEach(cat => { %>
            <a href="/vehicles?category=<%= cat.name.toLowerCase() %>" style="
                background: linear-gradient(135deg, <%= cat.color %>20 0%, <%= cat.color %>05 100%);
                border: 2px solid <%= cat.color %>;
                border-radius: 12px;
                padding: 2rem;
                text-align: center;
                text-decoration: none;
                color: var(--text-dark);
                transition: all 0.3s ease;
                cursor: pointer;
            " onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 16px rgba(0,0,0,0.1)';" 
               onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
                <div style="font-size: 3rem; margin-bottom: 1rem;"><%= cat.icon %></div>
                <h3 style="margin-bottom: 0.5rem; color: var(--text-dark);"><%= cat.name %></h3>
                <p style="color: var(--text-light); font-size: 0.9rem;">Başla →</p>
            </a>
        <% }); %>
    </div>
</section>

<!-- FEATURED VEHICLES -->
<section class="mb-3">
    <h2 style="margin-bottom: 2rem; text-align: center; font-size: 2rem;">Öne Çıkan Araçlar</h2>
    <div class="grid grid-3">
        <% 
            const vehicles = [
                { id: 1, name: 'Toyota Corolla', category: 'Ekonomik', price: 500, image: '/img/vehicle-1.jpg', rating: 4.8, fuel: 'Benzin', seats: 5 },
                { id: 2, name: 'Renault Clio', category: 'Ekonomik', price: 450, image: '/img/vehicle-2.jpg', rating: 4.7, fuel: 'Dizel', seats: 5 },
                { id: 3, name: 'Hyundai i10', category: 'Ekonomik', price: 350, image: '/img/vehicle-3.jpg', rating: 4.6, fuel: 'Benzin', seats: 4 },
                { id: 4, name: 'BMW X5', category: 'SUV', price: 2500, image: '/img/vehicle-4.jpg', rating: 4.9, fuel: 'Benzin', seats: 7 },
                { id: 5, name: 'Audi Q7', category: 'SUV', price: 2800, image: '/img/vehicle-5.jpg', rating: 4.9, fuel: 'Dizel', seats: 7 },
                { id: 6, name: 'Mercedes-Benz E-Class', category: 'Lüks', price: 3500, image: '/img/vehicle-6.jpg', rating: 5.0, fuel: 'Benzin', seats: 5 }
            ];
        %>
        <% vehicles.forEach(vehicle => { %>
            <div style="
                background: white;
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 2px 8px rgba(0,0,0,0.08);
                transition: all 0.3s ease;
                cursor: pointer;
            " onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 12px 24px rgba(0,0,0,0.15)';" 
               onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">
                <div style="
                    background: linear-gradient(135deg, var(--secondary) 0%, #2D3E5F 100%);
                    height: 200px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: white;
                    font-size: 3rem;
                ">
                    🚗
                </div>
                <div style="padding: 1.5rem;">
                    <span style="
                        display: inline-block;
                        background: var(--accent);
                        color: white;
                        padding: 0.25rem 0.75rem;
                        border-radius: 20px;
                        font-size: 0.75rem;
                        font-weight: 600;
                        margin-bottom: 0.5rem;
                    "><%= vehicle.category %></span>
                    <h3 style="margin-bottom: 0.5rem; color: var(--text-dark);"><%= vehicle.name %></h3>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; font-size: 0.9rem; color: var(--text-light);">
                        <span>⭐ <%= vehicle.rating %> (45 yorum)</span>
                        <span><%= vehicle.seats %> kişi</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 1rem; border-top: 1px solid var(--border);">
                        <span style="font-size: 1.5rem; font-weight: 700; color: var(--primary);">
                            <%= new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(vehicle.price) %>/gün
                        </span>
                        <a href="/vehicles/<%= vehicle.slug %>" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Detay</a>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
</section>

<!-- TESTIMONIALS -->
<section style="background: linear-gradient(135deg, var(--light) 0%, #E0F2FE 100%); padding: 3rem 2rem; border-radius: 12px; margin-bottom: 3rem;">
    <h2 style="margin-bottom: 2rem; text-align: center; font-size: 2rem;">Müşteri Yorumları</h2>
    <div class="grid grid-3">
        <% 
            const testimonials = [
                { name: 'Ahmet Yılmaz', text: 'Çok profesyonel bir hizmet aldım. Araç temiz ve güvenilir. Tekrar kullanırım.', rating: 5 },
                { name: 'Ayşe Demir', text: 'Uygun fiyatlar ve hızlı rezervasyon süreci. Çok memnun kaldım.', rating: 5 },
                { name: 'Mehmet Kaya', text: 'Kiralama işlemi çok basit ve anlaşılır. Tavsiye ediyorum.', rating: 4 }
            ];
        %>
        <% testimonials.forEach(test => { %>
            <div style="
                background: white;
                padding: 1.5rem;
                border-radius: 8px;
                border-left: 4px solid var(--primary);
            ">
                <div style="margin-bottom: 1rem;">
                    <% for (let i = 0; i < test.rating; i++) { %>
                        <span style="color: #FBBF24;">⭐</span>
                    <% } %>
                </div>
                <p style="margin-bottom: 1rem; color: var(--text-dark);">"<%= test.text %>"</p>
                <p style="font-weight: 600; color: var(--secondary);"><%= test.name %></p>
            </div>
        <% }); %>
    </div>
</section>

<!-- CTA SECTION -->
<section style="background: linear-gradient(135deg, var(--primary) 0%, #E55A2B 100%); color: white; padding: 3rem 2rem; text-align: center; border-radius: 12px;">
    <h2 style="margin-bottom: 1rem; font-size: 2rem;">Hemen Başlayın</h2>
    <p style="margin-bottom: 2rem; font-size: 1.1rem; color: rgba(255,255,255,0.9);">En uygun fiyatlarla araç kiralayın. Sorular mı var?</p>
    <a href="/contact" class="btn btn-secondary" style="margin-right: 1rem; display: inline-block;">İletişime Geç</a>
    <a href="https://wa.me/5442896055?text=Merhaba%2C%20araç%20kiralama%20hakkında%20bilgi%20almak%20istiyorum" class="btn" style="background: white; color: var(--primary); display: inline-block;">WhatsApp'tan Yazın</a>
</section>
